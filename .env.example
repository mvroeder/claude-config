# ============================================================
# exe.dev Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env && chmod 600 .env
#
# NEVER commit .env — it contains secrets!
# ============================================================

# --- Claude API ---
ANTHROPIC_API_KEY=

# --- Optional: Use exe.dev LLM Gateway instead of direct API ---
# If set, Claude Code will route through exe.dev's built-in gateway
# and you don't need ANTHROPIC_API_KEY above.
# EXE_LLM_GATEWAY=true

# --- Research Skill (optional) ---
# Required for /research-last30days skill
# OPENAI_API_KEY=
# XAI_API_KEY=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# --- Integrations (optional, for future agent features) ---
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
